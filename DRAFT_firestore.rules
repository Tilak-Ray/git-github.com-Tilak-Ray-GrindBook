rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isVerified() { return request.auth.token.email_verified == true; }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 50 &&
             (data.get('bio', '') is string && data.get('bio', '').size() <= 500);
    }

    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'title', 'completed']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.completed is bool;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'content', 'createdAt']) &&
             data.authorId == request.auth.uid &&
             data.content is string && data.content.size() <= 2000 &&
             data.createdAt == request.time;
    }

    // --- Collection Matches ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid; // Secured list
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'stats', 'mindset']);
    }

    match /users/{userId}/tasks/{taskId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidTask(incoming()) && isValidId(taskId);
      allow update: if isOwner(userId) && isValidTask(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'completed', 'priority', 'dueDate']);
      allow delete: if isOwner(userId);
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPost(incoming()) && isValidId(postId);
      allow update: if isSignedIn() && existing().authorId == request.auth.uid && 
                    isValidPost(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['content', 'imageUrl', 'likesCount', 'commentsCount']);
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;
    }

    match /friendships/{friendshipId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.users);
      allow create: if isSignedIn() && (request.auth.uid in incoming().users) && isValidId(friendshipId);
      allow update: if isSignedIn() && (request.auth.uid in existing().users) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }
  }
}
